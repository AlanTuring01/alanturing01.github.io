---
import Base from '../layouts/Base.astro';

const friends = [
  {
    name: 'Ausert',
    url: 'https://ausertdream.github.io',
    desc: '老朋友的博客。',
  },
];
---

<Base title="友链" description="杨坤的朋友们。">
  <div class="container page-head stagger">
    <p class="eyebrow reveal">FRIENDS</p>
    <h1 class="heading-beacon reveal">友链</h1>
    <p class="reveal">同一片深空下的其他航船。</p>
  </div>

  <div class="container">
    <ul class="friend-grid stagger" role="list">
      {
        friends.map((f) => (
          <li class="reveal">
            <a class="card friend" href={f.url} target="_blank" rel="noopener noreferrer">
              <span class="badge num" aria-hidden="true">{f.name[0]}</span>
              <span class="info">
                <span class="name">{f.name}</span>
                <span class="desc">{f.desc}</span>
              </span>
            </a>
          </li>
        ))
      }
      <li class="reveal">
        <div class="card friend apply">
          <span class="badge plus" aria-hidden="true">+</span>
          <span class="info">
            <span class="name">申请友链</span>
            <span class="desc">
              到<a href="/guestbook/">留言板</a>留下你的站点，或在
              <a href="https://github.com/AlanTuring01/alanturing01.github.io/issues" target="_blank" rel="noopener noreferrer">GitHub</a>
              提个 issue。
            </span>
          </span>
        </div>
      </li>
    </ul>
  </div>
</Base>

<style>
  .page-head {
    padding-block: 4rem 1.5rem;
  }

  .friend-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: 1rem;
    list-style: none;
    margin: 0 0 3rem;
    padding: 0;
  }

  .friend {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.3rem;
    background-image: none;
    color: var(--text-1);
    height: 100%;
  }

  .badge {
    flex: none;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--accent-contrast);
    background: var(--aurora);
  }

  .badge.plus {
    background: transparent;
    border: 1px dashed var(--border-c);
    color: var(--text-2);
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .name {
    font-weight: 600;
    color: var(--text-0);
  }

  a.friend:hover .name {
    color: var(--accent);
  }

  .desc {
    font-size: var(--fs-small);
    color: var(--text-2);
  }
</style>
