---
const links = [
  { href: '/', label: '首页' },
  { href: '/posts/', label: '文字' },
  { href: '/gallery/', label: '相册' },
  { href: '/videos/', label: '视频' },
  { href: '/guestbook/', label: '留言板' },
  { href: '/about/', label: '关于' },
];

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header class="site-header">
  <nav class="glass" aria-label="主导航">
    <div class="container nav-inner">
      <a href="/" class="brand">
        <svg width="22" height="22" viewBox="0 0 64 64" aria-hidden="true">
          <defs>
            <linearGradient id="nav-aurora" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#43E9C0"></stop>
              <stop offset=".38" stop-color="#4E9BFF"></stop>
              <stop offset=".66" stop-color="#8B7BFF"></stop>
              <stop offset="1" stop-color="#FF7BC8"></stop>
            </linearGradient>
          </defs>
          <rect x="16" y="16" width="32" height="32" rx="5" fill="url(#nav-aurora)" transform="rotate(45 32 32)"></rect>
        </svg>
        <span>杨坤的博客</span>
      </a>
      <button id="nav-toggle" class="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="打开菜单">
        <span class="bar" aria-hidden="true"></span>
        <span class="bar" aria-hidden="true"></span>
      </button>
      <div id="nav-menu" class="nav-menu">
        <ul>
          {
            links.map((l) => (
              <li>
                <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
        <button id="theme-toggle" class="theme-toggle" aria-label="切换深浅主题">
          <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
          </svg>
          <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    border-left: 0;
    border-right: 0;
    border-top: 0;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-height: 3.4rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text-0);
    background-image: none;
    margin-right: auto;
  }

  .brand svg {
    flex: none;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nav-menu ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  .nav-menu ul a {
    display: block;
    padding: 0.35em 0.75em;
    border-radius: 999px;
    color: var(--text-1);
    font-size: var(--fs-small);
    background-image: none;
    transition: color var(--t-fast) var(--ease-out), background-color var(--t-fast) var(--ease-out);
  }

  .nav-menu ul a:hover {
    color: var(--accent);
  }

  .nav-menu ul a[aria-current='page'] {
    color: var(--accent);
    background-color: var(--code-bg);
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 50%;
    border: 1px solid var(--border-c);
    background: transparent;
    color: var(--text-1);
    cursor: pointer;
    transition: color var(--t-fast) var(--ease-out), border-color var(--t-fast) var(--ease-out);
  }

  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  :global(:root[data-theme='light']) .icon-moon {
    display: none;
  }

  :global(:root:not([data-theme='light'])) .icon-sun {
    display: none;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.2rem;
    height: 2.2rem;
    border: 0;
    background: transparent;
    cursor: pointer;
    padding: 0.4rem;
  }

  .nav-toggle .bar {
    display: block;
    height: 2px;
    border-radius: 2px;
    background: var(--text-0);
    transition: transform var(--t-base) var(--ease-out);
  }

  @media (max-width: 760px) {
    .nav-toggle {
      display: flex;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      padding: 0.75rem 1.25rem 1.25rem;
      background: var(--bg-1);
      border-bottom: 1px solid var(--border-c);
      display: none;
    }

    .nav-menu.open {
      display: flex;
    }

    .nav-menu ul {
      flex-direction: column;
      width: 100%;
    }

    .nav-menu ul a {
      padding: 0.7em 0.75em;
      font-size: var(--fs-body);
    }

    .theme-toggle {
      align-self: flex-start;
      margin-left: 0.4rem;
    }
  }
</style>
